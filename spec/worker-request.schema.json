{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:aster:schema:worker-request:v1",
  "title": "runx Worker Request",
  "description": "Canonical prerelease v1 discriminated union for governed worker packets.",
  "oneOf": [
    {
      "$ref": "#/$defs/issueToPrWorkerRequest"
    }
  ],
  "$defs": {
    "issueToPrRequest": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "issue_title": {
          "type": "string",
          "minLength": 1
        },
        "issue_body": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "target_repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "branch": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "size": {
          "type": "string",
          "enum": [
            "small",
            "medium",
            "large"
          ]
        },
        "risk": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "phase": {
          "type": "string",
          "minLength": 1
        },
        "verification_profile": {
          "type": "string",
          "minLength": 1
        },
        "validation_command": {
          "type": "string",
          "minLength": 1
        },
        "validation_commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "issue_title",
        "source",
        "source_id"
      ],
      "additionalProperties": false
    },
    "issueToPrWorkerRequest": {
      "type": "object",
      "properties": {
        "worker": {
          "const": "issue-to-pr"
        },
        "issue_to_pr_request": {
          "$ref": "#/$defs/issueToPrRequest"
        },
        "request": {
          "$ref": "#/$defs/issueToPrRequest"
        }
      },
      "required": [
        "worker"
      ],
      "anyOf": [
        {
          "required": [
            "issue_to_pr_request"
          ]
        },
        {
          "required": [
            "request"
          ]
        }
      ],
      "additionalProperties": false
    }
  }
}
