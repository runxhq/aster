{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runx.ai/spec/governance/verification-proof.schema.json",
  "title": "runx Verification Proof",
  "description": "Canonical prerelease v1 schema for verification proof artifacts emitted before publication.",
  "type": "object",
  "properties": {
    "proof_id": {
      "type": "string",
      "minLength": 1
    },
    "target_repo": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "verification_profile": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "pass",
        "fail",
        "skipped"
      ]
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verificationCheck"
      }
    },
    "summary": {
      "type": "string"
    },
    "verified_at": {
      "type": "string",
      "format": "date-time"
    },
    "harness_receipt_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    }
  },
  "required": [
    "target_repo",
    "verification_profile",
    "status",
    "checks"
  ],
  "additionalProperties": false,
  "$defs": {
    "verificationCheck": {
      "type": "object",
      "properties": {
        "check_id": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "enum": [
            "bootstrap",
            "verification"
          ]
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "skipped"
          ]
        },
        "exit_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "check_id",
        "phase",
        "command",
        "status"
      ],
      "additionalProperties": false
    },
    "reference": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "locator": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "kind",
        "locator"
      ],
      "additionalProperties": false
    }
  }
}
