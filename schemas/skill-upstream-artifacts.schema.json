{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runx.ai/schemas/skill-upstream-artifacts.schema.json",
  "title": "runx skill contribution artifact bundle",
  "type": "object",
  "required": [
    "skill_opportunity",
    "skill_recon_report",
    "skill_candidate",
    "contribution_packet",
    "public_feed_event"
  ],
  "properties": {
    "skill_opportunity": {
      "$ref": "#/$defs/skillOpportunity"
    },
    "skill_recon_report": {
      "$ref": "#/$defs/skillResearchReport"
    },
    "skill_candidate": {
      "$ref": "#/$defs/skillCandidate"
    },
    "contribution_packet": {
      "$ref": "#/$defs/contributionPacket"
    },
    "public_feed_event": {
      "$ref": "#/$defs/publicFeedEvent"
    }
  },
  "$defs": {
    "skillOpportunity": {
      "type": "object",
      "required": ["schema", "id", "mode", "state", "target", "opportunity", "selection", "created_at"],
      "properties": {
        "schema": {
          "const": "runx.skill_opportunity.v1"
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "enum": ["auto", "requested"]
        },
        "state": {
          "const": "discovered"
        },
        "target": {
          "type": "object",
          "required": ["host", "owner", "repo", "candidate_path"],
          "properties": {
            "host": {
              "type": "string"
            },
            "owner": {
              "type": "string"
            },
            "repo": {
              "type": "string"
            },
            "default_branch": {
              "type": "string"
            },
            "candidate_path": {
              "type": "string"
            },
            "remote_url": {
              "type": "string"
            },
            "commit": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "opportunity": {
          "type": "object",
          "required": ["workflow", "summary", "source_signals"],
          "properties": {
            "workflow": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "ecosystem": {
              "type": "string"
            },
            "source_signals": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        },
        "selection": {
          "type": "object",
          "required": ["reasons"],
          "properties": {
            "score": {
              "type": "number"
            },
            "reasons": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "rejected_reasons": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": true
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "skillResearchReport": {
      "type": "object",
      "required": ["schema", "opportunity_id", "state", "findings", "sources", "risks", "recommended_flow"],
      "properties": {
        "schema": {
          "const": "runx.skill_recon_report.v1"
        },
        "opportunity_id": {
          "type": "string"
        },
        "state": {
          "const": "researched"
        },
        "findings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["claim", "source", "relevance", "confidence"],
            "properties": {
              "claim": {
                "type": "string"
              },
              "source": {
                "type": "string"
              },
              "relevance": {
                "type": "string"
              },
              "confidence": {
                "enum": ["verified", "likely", "unverified"]
              }
            },
            "additionalProperties": true
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "recommended_flow": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": true
    },
    "skillCandidate": {
      "type": "object",
      "required": ["schema", "opportunity_id", "state", "skill", "quality", "registry_binding"],
      "properties": {
        "schema": {
          "const": "runx.skill_candidate.v1"
        },
        "opportunity_id": {
          "type": "string"
        },
        "state": {
          "const": "candidate_authored"
        },
        "skill": {
          "type": "object",
          "required": ["name", "description", "path", "portable", "requires_runx"],
          "properties": {
            "name": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "portable": {
              "const": true
            },
            "requires_runx": {
              "const": false
            }
          },
          "additionalProperties": true
        },
        "quality": {
          "type": "object",
          "required": ["repo_grounded", "mentions_runx_as_optional", "requires_platform_dependency"],
          "properties": {
            "repo_grounded": {
              "const": true
            },
            "mentions_runx_as_optional": {
              "type": "boolean"
            },
            "requires_platform_dependency": {
              "const": false
            }
          },
          "additionalProperties": true
        },
        "registry_binding": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "contributionPacket": {
      "type": "object",
      "required": ["schema", "opportunity_id", "state", "target", "changes", "pull_request", "review"],
      "properties": {
        "schema": {
          "const": "runx.skill_upstream.v1"
        },
        "opportunity_id": {
          "type": "string"
        },
        "state": {
          "enum": ["contribution_ready", "submitted_upstream", "maintainer_review", "accepted_upstream", "rejected_upstream", "stale_upstream"]
        },
        "target": {
          "type": "object",
          "required": ["repo", "branch", "base", "path"],
          "properties": {
            "repo": {
              "type": "string"
            },
            "branch": {
              "type": "string"
            },
            "base": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "commit": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "changes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "kind"],
            "properties": {
              "path": {
                "type": "string"
              },
              "kind": {
                "const": "portable-skill"
              }
            },
            "additionalProperties": true
          }
        },
        "pull_request": {
          "type": "object"
        },
        "review": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "publicFeedEvent": {
      "type": "object",
      "required": ["lane", "summary", "status", "metadata"],
      "properties": {
        "lane": {
          "const": "skill-upstream"
        },
        "summary": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "metadata": {
          "type": "object",
          "required": ["state", "target_repo", "skill_path", "checks_total", "checks_passed"],
          "properties": {
            "state": {
              "type": "string"
            },
            "target_repo": {
              "type": "string"
            },
            "skill_path": {
              "type": "string"
            },
            "checks_total": {
              "type": "number"
            },
            "checks_passed": {
              "type": "number"
            },
            "checks_failed": {
              "type": "number"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
