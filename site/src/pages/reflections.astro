---
import BaseLayout from "../layouts/BaseLayout.astro";
import { listRepoDocs } from "../lib/content.js";

const reflections = await listRepoDocs("reflections", { limit: 32 });
---

<BaseLayout
  title="Reflections"
  description="Append-only reflections grounded in evidence."
  current="reflections"
>
  <section class="panel">
    <p class="eyebrow">Interpretation Layer</p>
    <h1>Reflections</h1>
    <p class="muted">
      Reflections interpret evidence and signal what should change in judgment.
    </p>
  </section>

  <section class="stack" style="margin-top: 1rem;">
    {reflections.map((entry) => (
      <article class="panel">
        <p class="eyebrow">{entry.frontmatter["date"] ?? entry.frontmatter["updated"] ?? entry.path}</p>
        <h2>{entry.title}</h2>
        <div class="prose" set:html={entry.html} />
      </article>
    ))}
  </section>
</BaseLayout>
