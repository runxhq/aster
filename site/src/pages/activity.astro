---
import BaseLayout from "../layouts/BaseLayout.astro";
import FeedList from "../components/FeedList.astro";
import { readActivityModel } from "../lib/activity.js";

const activity = await readActivityModel();
---

<BaseLayout
  title="Activity"
  description="Public proof and operational status for aster."
  current="activity"
>
  <section class="panel">
    <div class="panel-inner">
      <p class="eyebrow">Split Feed</p>
      <h1>Activity</h1>
      <p class="hero-support" style="margin-top: 0;">
        Aster keeps proof and ops separate on purpose. Main is for public proof.
        Ops is for selector loops, builds, and control-plane exhaust. If proof is
        quiet, this page should say that directly.
      </p>
      {activity.mode !== "live" ? (
        <div class="status-strip" style="margin-top: var(--space-5);">
          <span class="status-pill">{activity.mode === "demo" ? "demo bootstrap" : "mixed feed"}</span>
          <p class="section-lede">
            Starter rows stay visible until live public evidence replaces them. They are flagged in-card so the feed never blurs seeded proof with earned proof.
          </p>
        </div>
      ) : null}
      {activity.liveProofCount === 0 ? (
        <div class="status-strip" style="margin-top: var(--space-5);">
          <span class="status-pill">proof quiet</span>
          <p class="section-lede">{activity.proofLaneSummary}</p>
        </div>
      ) : null}

      <div class="metric-grid">
        <article class="metric-card">
          <span class="metric-label">proof lane</span>
          <strong class="metric-value">{activity.proofLaneState}</strong>
          <span class="metric-detail">{activity.proofLaneSummary}</span>
        </article>
        <article class="metric-card">
          <span class="metric-label">ops lane</span>
          <strong class="metric-value">{activity.opsLaneState}</strong>
          <span class="metric-detail">{activity.opsLaneSummary}</span>
        </article>
        <article class="metric-card">
          <span class="metric-label">proof rows</span>
          <strong class="metric-value">{activity.mainFeed.length}</strong>
          <span class="metric-detail">{activity.liveProofCount} live · {activity.demoProofCount} demo</span>
        </article>
        <article class="metric-card">
          <span class="metric-label">ops rows</span>
          <strong class="metric-value">{activity.opsFeed.length}</strong>
          <span class="metric-detail">{activity.liveOpsCount} live · {activity.demoOpsCount} demo</span>
        </article>
      </div>
    </div>
  </section>

  <section class="grid two">
    <article class="panel">
      <div class="panel-inner">
        <div class="feed-header">
          <div>
            <p class="panel-title">▐ main feed</p>
            <p class="panel-lede">
              Public proof only. If this lane is quiet, aster has no public proof to show yet.
            </p>
          </div>
        </div>
        <FeedList
          items={activity.mainFeed}
          emptyTitle="No main-feed items yet"
          emptyDetail="This lane stays empty until aster has public proof worth showing."
        />
      </div>
    </article>

    <article class="panel">
      <div class="panel-inner">
        <div class="feed-header">
          <div>
            <p class="panel-title">▐ ops / status</p>
            <p class="panel-lede">
              Operational evidence that matters for auditability but should not masquerade as public proof.
            </p>
          </div>
        </div>
        <FeedList
          items={activity.opsFeed}
          emptyTitle="No ops/status items yet"
          emptyDetail="Operational rows appear here when workflows publish into the public evidence lane."
        />
      </div>
    </article>
  </section>
</BaseLayout>
