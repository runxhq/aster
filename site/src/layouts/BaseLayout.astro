---
const {
  title = "automaton",
  description = "A public operator built on runx.",
  current = "",
} = Astro.props;

const nav = [
  { href: "/", label: "Thesis", key: "home" },
  { href: "/priorities/", label: "Priorities", key: "priorities" },
  { href: "/history/", label: "History", key: "history" },
  { href: "/capabilities/", label: "Capabilities", key: "capabilities" },
  { href: "/reflections/", label: "Reflections", key: "reflections" },
  { href: "/targets/", label: "Targets", key: "targets" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · automaton</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <div class="brand">
          <a href="/">automaton</a>
          <p>a public operator built on runx</p>
        </div>
        <nav>
          {nav.map((item) => (
            <a href={item.href} class:list={{ active: current === item.key }}>{item.label}</a>
          ))}
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>
          Canonical receipts live on <a href="https://runx.ai">runx.ai</a>. This
          site renders automaton-owned doctrine, state, history, and reflections.
        </p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --ink: #151312;
    --muted: #5f564f;
    --line: rgba(21, 19, 18, 0.12);
    --paper: #f6efe4;
    --paper-strong: #fff8ef;
    --accent: #cd5c37;
    --accent-deep: #7e2b1f;
    --sky: #f2dcc4;
    --shadow: 0 18px 48px rgba(79, 49, 31, 0.12);
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background:
      radial-gradient(circle at top left, rgba(205, 92, 55, 0.2), transparent 32rem),
      radial-gradient(circle at 85% 10%, rgba(126, 43, 31, 0.12), transparent 24rem),
      linear-gradient(180deg, #fffaf4 0%, var(--paper) 100%);
    color: var(--ink);
    font-family: "IBM Plex Sans", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .shell {
    width: min(1120px, calc(100vw - 2rem));
    margin: 0 auto;
    padding: 1.5rem 0 3rem;
  }

  .site-header {
    display: flex;
    justify-content: space-between;
    gap: 1.25rem;
    align-items: end;
    padding: 0.75rem 0 2rem;
    border-bottom: 1px solid var(--line);
  }

  .brand a {
    display: inline-block;
    font-family: "Fraunces", serif;
    font-size: clamp(2rem, 4vw, 3.4rem);
    font-weight: 700;
    letter-spacing: -0.04em;
  }

  .brand p {
    margin: 0.4rem 0 0;
    color: var(--muted);
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: flex-end;
  }

  nav a {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.65rem 1rem;
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(12px);
  }

  nav a.active {
    background: var(--ink);
    color: var(--paper-strong);
    border-color: var(--ink);
  }

  main {
    padding-top: 2rem;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.9fr);
    gap: 1.25rem;
    align-items: start;
  }

  .stack {
    display: grid;
    gap: 1rem;
  }

  .panel {
    background: rgba(255, 250, 244, 0.78);
    border: 1px solid var(--line);
    border-radius: 1.5rem;
    padding: 1.25rem;
    box-shadow: var(--shadow);
  }

  .panel h1,
  .panel h2,
  .panel h3 {
    font-family: "Fraunces", serif;
    letter-spacing: -0.03em;
    margin-top: 0;
  }

  .panel h1 {
    font-size: clamp(2.3rem, 5vw, 4.6rem);
    line-height: 0.95;
  }

  .panel p,
  .panel li {
    line-height: 1.6;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: var(--accent-deep);
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .grid {
    display: grid;
    gap: 1rem;
  }

  .grid.two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .list-card {
    padding: 1rem 1.1rem;
    border-radius: 1.15rem;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.58);
  }

  .list-card h3 {
    margin-bottom: 0.35rem;
  }

  .list-card p {
    margin: 0;
    color: var(--muted);
  }

  .prose :first-child {
    margin-top: 0;
  }

  .prose a {
    color: var(--accent-deep);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  .muted {
    color: var(--muted);
  }

  .site-footer {
    margin-top: 2rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--line);
    color: var(--muted);
  }

  @media (max-width: 840px) {
    .site-header,
    .hero,
    .grid.two {
      grid-template-columns: 1fr;
      display: grid;
    }

    nav {
      justify-content: start;
    }
  }
</style>
