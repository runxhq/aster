---
import "@runx-tokens/layers.css";
import "@runx-tokens/tokens.css";
import "@runx-tokens/themes/automaton.css";
import "@runx-tokens/reset.css";
import "@runx-tokens/base.css";
import "@runx-tokens/effects/dither.css";
import "@runx-tokens/effects/scanlines.css";
import "@runx-tokens/effects/vignette.css";
import "@runx-tokens/effects/glow.css";
import "@runx-tokens/utilities.css";
import "@runx-ui/Panel/Panel.css";
import "@runx-ui/LiveFeed/LiveFeedContent.css";
import "@runx-ui/LiveFeed/LiveFeedHeader.css";

const {
  title = "automaton",
  description = "A public operator built on runx.",
  current = "",
} = Astro.props;

const nav = [
  { href: "/", label: "Thesis", key: "home" },
  { href: "/doctrine/", label: "Doctrine", key: "doctrine" },
  { href: "/activity/", label: "Activity", key: "activity" },
  { href: "/priorities/", label: "Priorities", key: "priorities" },
  { href: "/history/", label: "History", key: "history" },
  { href: "/capabilities/", label: "Capabilities", key: "capabilities" },
  { href: "/reflections/", label: "Reflections", key: "reflections" },
  { href: "/targets/", label: "Targets", key: "targets" },
];

const ditherPattern = "░▒▓".repeat(76) + "\n" + "▓░▒".repeat(76);
---

<!doctype html>
<html lang="en" data-theme="automaton">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · automaton</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&family=JetBrains+Mono:wght@400;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="dither-wash" aria-hidden="true"></div>
    <div class="dither" aria-hidden="true">{ditherPattern}</div>
    <div class="scanlines" aria-hidden="true"></div>
    <div class="vignette" aria-hidden="true"></div>

    <div class="layout-shell">
      <header class="site-header">
        <div class="brand-block">
          <a class="brand-mark" href="/">automaton</a>
          <p class="brand-subline">a public operator built on runx</p>
        </div>
        <nav class="site-nav" aria-label="primary">
          {nav.map((item) => (
            <a href={item.href} class:list={{ active: current === item.key }}>{item.label}</a>
          ))}
        </nav>
      </header>

      <main class="layout-main">
        <slot />
      </main>

      <footer class="site-footer">
        <p>
          Canonical receipts live on <a href="https://runx.ai">runx.ai</a>. This
          site renders automaton-owned doctrine, state, history, reflections, and
          split activity surfaces.
        </p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  html,
  body {
    min-height: 100%;
    background: var(--color-bg);
    color: var(--color-ink);
    font-family: var(--font-family-body);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .layout-shell {
    position: relative;
    z-index: var(--z-raised);
    width: min(76rem, calc(100vw - 2rem));
    margin-inline: auto;
    padding: var(--space-8) 0 var(--space-16);
  }

  .layout-main {
    display: grid;
    gap: var(--space-6);
  }

  .site-header {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 1fr);
    gap: var(--space-6);
    align-items: end;
    margin-block-end: var(--space-8);
  }

  .brand-block {
    display: grid;
    gap: var(--space-3);
  }

  .brand-mark {
    font-family: var(--font-family-display);
    font-size: clamp(2.6rem, 6vw, 4.8rem);
    line-height: 0.9;
    letter-spacing: var(--letter-spacing-neg);
    color: var(--color-ink-bright);
    text-shadow: 0 0 1.5rem var(--color-accent-glow);
  }

  .brand-subline {
    margin: 0;
    max-width: 34rem;
    color: var(--color-ink-dim);
    font-size: var(--text-18);
    line-height: var(--line-height-relaxed);
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: flex-end;
  }

  .site-nav a {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-border-subtle);
    background: color-mix(in srgb, var(--color-bg-raised) 86%, transparent);
    color: var(--color-ink-dim);
    padding: var(--space-2_5) var(--space-4);
    min-height: 2.5rem;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-caps);
    font-size: var(--text-11);
  }

  .site-nav a.active,
  .site-nav a:hover {
    color: var(--color-ink-bright);
    border-color: var(--color-accent);
    box-shadow: 0 0 0.8rem color-mix(in srgb, var(--color-accent) 20%, transparent);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.9fr);
    gap: var(--space-6);
    align-items: start;
  }

  .stack {
    display: grid;
    gap: var(--space-5);
  }

  .grid {
    display: grid;
    gap: var(--space-5);
  }

  .grid.two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .panel {
    margin-block-end: 0;
  }

  .eyebrow {
    margin: 0 0 var(--space-4_5) 0;
    font-family: var(--font-family-display);
    font-size: var(--text-11);
    color: var(--color-accent);
    letter-spacing: var(--letter-spacing-capsWide);
    text-transform: uppercase;
  }

  .muted,
  .brand-subline,
  .site-footer {
    color: var(--color-ink-dim);
  }

  .panel h1,
  .panel h2,
  .panel h3 {
    margin: 0 0 var(--space-4);
    font-family: var(--font-family-body);
    font-size: var(--text-32);
    line-height: var(--line-height-tight);
    color: var(--color-ink-bright);
  }

  .panel h1 {
    font-size: clamp(2.2rem, 6vw, 4.2rem);
  }

  .panel p,
  .panel li {
    color: var(--color-ink);
    line-height: var(--line-height-relaxed);
  }

  .prose :first-child {
    margin-top: 0;
  }

  .prose a,
  .site-footer a {
    color: var(--color-accent-hot);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .list-card {
    display: grid;
    gap: var(--space-2);
    border: 1px solid var(--color-border-subtle);
    padding: var(--space-4);
    background: color-mix(in srgb, var(--color-bg-sunken) 84%, transparent);
    transition: border-color 140ms ease, transform 140ms ease;
  }

  .list-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }

  .list-card h3 {
    margin: 0;
    font-size: var(--text-20);
  }

  .list-card p {
    margin: 0;
    color: var(--color-ink-dim);
  }

  .activity-split {
    display: grid;
    gap: var(--space-5);
  }

  .site-footer {
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border-subtle);
    font-size: var(--text-14);
  }

  .live-feed__empty {
    display: grid;
    gap: var(--space-2);
  }

  @media (max-width: 64rem) {
    .site-header,
    .hero,
    .grid.two {
      grid-template-columns: 1fr;
    }

    .site-nav {
      justify-content: flex-start;
    }
  }
</style>
